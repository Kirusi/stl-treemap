{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Python Debugger: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "PYTEST: Current File",
      "type": "debugpy",
      "request": "launch",
      "program": "./.venv/bin/pytest",
      "args": [
        "-s",
        "-vv",
        "${file}"
      ],
      "console": "integratedTerminal",
      //"justMyCode": false
    },
  ]
}